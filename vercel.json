{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pip install -r requirements.txt",
  "devCommand": "pip install -r requirements.txt && python -m uvicorn app.fastapi_app:app --reload",
  "installCommand": "pip install -r requirements.txt",
  "framework": null,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "python3.13",
      "maxDuration": 300
    }
  },
  "env": {
    "OPENQUEUE_ENV": "prod",
    "OPENQUEUE_RATE_LIMIT_ENABLED": "false"
  }
}
